# ====================================================================
# AeroShield HSE Systems - Local Configuration Environment File
# ====================================================================
# Copy this file or fill in the keys below to override simulator data
# with live real-time AQI reports from international monitoring stations.

# 1. World Air Quality Index (WAQI) token
# Get a free developer token at: https://aqicn.org/data-platform/token/
WAQI_API_TOKEN=your_real_waqi_api_token_here

# 2. OpenAQ API Key
# Get a developer key at: https://openaq.org/
OPENAQ_API_KEY=your_real_openaq_api_key_here

# 3. Database Connection (Optional MongoDB Atlas URI)
# Leaving this empty triggers local high-fidelity JSON data fallback
MONGO_URI=

# 4. Global Encryption Secret
JWT_SECRET=super_secret_aqi_prediction_system_token_key_12345

# 5. Mode Override Flags (true/false)
FORCE_SIMULATOR=false
